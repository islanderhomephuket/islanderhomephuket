# ─────────────────────────────────────────────────────────────
# Islander Home Phuket — environment variables
# Copy this file to `.env.local` and fill in your values.
# The site runs in DEMO mode (rich mock data) until Supabase is set.
# ─────────────────────────────────────────────────────────────

# Supabase — https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (server-only, NEVER expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# Admin dashboard login (used by the cookie-based admin gate)
ADMIN_PASSWORD=changeme

# Public site URL (used for SEO canonical / sitemap / OG tags)
NEXT_PUBLIC_SITE_URL=https://islanderhomephuket.com

# Google Maps embed key (optional — falls back to a keyless embed)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

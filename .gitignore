# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Full-resolution photo backup — keep OUT of git (huge). Web-optimized
# copies live in public/listings/ and are committed.
public/_listings_ORIGINAL_BACKUP/
